{
  "name": "@vrugtehagel/eleventy-site-search",
  "version": "0.0.15",
  "exports": "./mod.ts",
  "publish": {
    "include": ["src/**", "mod.ts", "README.md"]
  },
  "tasks": {
    "check": "deno publish --dry-run --allow-dirty"
  },
  "lint": {
    "rules": {
      "exclude": ["no-explicit-any", "require-await"]
    }
  },
  "compilerOptions": {
    "lib": ["deno.worker"]
  },
  "imports": {
    "esbuild": "npm:esbuild@^0.28.1",
    "node-html-parser": "npm:node-html-parser@^7.1"
  }
}
